{
  "version": 2,
  "builds": [
    {
      "src": "api/track.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/track",
      "dest": "/api/track.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}